# Serve images only — never execute anything from this directory.
<IfModule mod_php.c>
  php_flag engine off
</IfModule>
RemoveHandler .php .phtml .php3 .php4 .php5 .php7 .php8 .pl .py .cgi .sh
RemoveType    .php .phtml .php3 .php4 .php5 .php7 .php8
<FilesMatch "\.(?i:php|phtml|pl|py|cgi|sh)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
  </IfModule>
</FilesMatch>
Options -Indexes -ExecCGI
